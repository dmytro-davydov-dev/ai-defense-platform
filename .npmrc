engine-strict=true
strict-peer-dependencies=false
auto-install-peers=true

# pnpm's default (isolated/symlinked) node_modules layout puts each
# workspace app's own dependencies in <app>/node_modules (symlinks into
# the root node_modules/.pnpm store), not in the root node_modules
# itself. Every app's Dockerfile runtime stage only does
# `COPY --from=build /workspace/node_modules ./node_modules` — with the
# default layout that misses e.g. apps/api/node_modules/@nestjs/core
# entirely, so the built image throws "Cannot find module '@nestjs/core'"
# (or 'pg', 'express', etc.) at container start despite a clean build.
# `hoisted` flattens every dependency into the root node_modules so the
# single COPY is actually sufficient — this is pnpm's own documented fix
# for multi-stage Docker builds that don't replicate the full workspace
# directory structure in the runtime stage.
node-linker=hoisted
