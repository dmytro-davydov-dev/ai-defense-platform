  "info": {
    "title": "AI Defense Platform API",
    "description": "Control-plane API — mission lifecycle, identity, upload, audit.",
    "version": "0.1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "operator@ai-defense.example"
          },
          "password": {
            "type": "string",
            "example": "correct horse battery staple",
            "minLength": 8
          },
          "displayName": {
            "type": "string",
            "example": "Jane Operator"
          }
        },
        "required": ["email", "password", "displayName"]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "operator@ai-defense.example"
          },
          "password": {
            "type": "string"
          }
        },
        "required": ["email", "password"]
      },
      "CreateMissionDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Coastal flyover — sector 4"
          },
          "description": {
            "type": "string",
            "example": "Weekly inspection pass, sector 4 shoreline."
          }
        },
        "required": ["title"]
      },
      "UpdateMissionMetadataDto": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "example": "Coastal flyover — sector 4 (rescheduled)"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "TransitionMissionDto": {
        "type": "object",
        "properties": {
          "targetState": {
            "type": "string",
            "enum": ["DRAFT", "QUEUED", "PROCESSING", "COMPLETED", "FAILED"],
            "example": "QUEUED"
          }
        },
        "required": ["targetState"]
      },
      "CreateUploadUrlDto": {
        "type": "object",
        "properties": {
          "fileName": {
            "type": "string",
            "example": "mission-42-flyover.mp4"
          },
          "contentType": {
            "type": "string",
            "example": "video/mp4"
          }
        },
        "required": ["fileName", "contentType"]
      }
    }
  }
}
