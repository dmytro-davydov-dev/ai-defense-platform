# Copy to .env and fill in local values. Never commit .env.
# Used by infrastructure/compose/docker-compose.yml (REQ-1.18: no
# secrets hardcoded in the repo).

# --- PostgreSQL + PostGIS ---
POSTGRES_USER=aidefense
POSTGRES_PASSWORD=changeme-local-only
POSTGRES_DB=aidefense
POSTGRES_PORT=5432

# --- Redpanda (Kafka API) ---
REDPANDA_KAFKA_PORT=19092
REDPANDA_ADMIN_PORT=9644
REDPANDA_PANDAPROXY_PORT=18082

# --- MinIO (S3-compatible object storage) ---
MINIO_ROOT_USER=aidefense
MINIO_ROOT_PASSWORD=changeme-local-only
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
# Bucket apps/api's StorageService creates on startup for mission video
# uploads (REQ-2.9) — not auto-created by the minio image itself.
MINIO_MISSIONS_BUCKET=mission-videos

# --- App shells ---
WEB_PORT=5173
API_PORT=3000
VISION_SERVICE_PORT=8000
NODE_ENV=development

# --- Auth (REQ-2.4, apps/api AuthModule) ---
# HS256 signing secret for issued JWTs. Local-dev-only value below —
# generate a real random secret (e.g. `openssl rand -hex 32`) for any
# shared/deployed environment.
JWT_SECRET=changeme-local-only-jwt-secret
JWT_EXPIRES_IN=1h

# --- apps/outbox-publisher (REQ-3.7) ---
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=20

# --- apps/web (docs/mvp-plan/PRD-Phase-6.md REQ-6.6/6.12) ---
# Read at Vite build time (import.meta.env.*), baked into the bundle —
# not re-readable at container-start time like the backend's env vars.
# Defaults (apps/web/src/api/apiSlice.ts, apps/web/src/features/realtime/useMissionSocket.ts)
# assume the browser can reach apps/api directly at localhost:3000, true
# for this Compose setup's published ports; override only if apps/api is
# served from a different origin.
VITE_API_BASE_URL=http://localhost:3000
VITE_WS_BASE_URL=http://localhost:3000
