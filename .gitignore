# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.next/
out/
*.tsbuildinfo

# Prisma generated client (regenerated via `prisma generate`, see
# apps/api/package.json's build/typecheck/test scripts)
apps/api/generated/

# Nx
.nx/cache/
.nx/workspace-data/

# Env
.env
.env.local
.env.*.local

# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
.ruff_cache/
*.egg-info/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/*
!.vscode/extensions.json
.idea/

# Docker volumes (local data, never committed)
infrastructure/compose/.data/

# Coverage
coverage/

# Phase 8 (docs/mvp-plan/PRD-Phase-8.md): local dataset/model staging
# only — real content lives in MinIO, never git, per
# docs/architecture/Repository_Structure.md's "datasets and model
# binaries are not committed unless explicitly licensed and small" rule.
# See datasets/README.md, models/README.md.
/datasets/*
!/datasets/README.md
!/datasets/.gitkeep
/models/*
!/models/README.md
!/models/.gitkeep

# Stray pnpm temp files this sandbox's filesystem can't delete once
# pnpm creates them (an interrupted `pnpm install`'s store-path check
# leaves these at the repo root) — harmless, but keep them out of git
# status/diffs rather than committing them.
/_tmp_*
