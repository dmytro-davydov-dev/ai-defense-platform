{
  "name": "@ai-defense/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "React + Vite operator Mission Workspace shell. Phase 1 scaffold; real UI lands in Phase 6.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "start": "node server.js",
    "preview": "vite preview",
