// Phase 2 data model — docs/mvp-plan/PRD-Phase-2.md REQ-2.1.
// ORM choice: docs/adr/ADR-004-nestjs-orm.md (Prisma).
// Mission state machine: docs/architecture/Mission_State_Machine.md.
//
// The datasource has no `url` field: in Prisma 7 the CLI (migrate,
// generate) reads the connection string from prisma.config.ts, and the
// runtime PrismaClient receives it explicitly via the @prisma/adapter-pg
// driver adapter in src/prisma/prisma.service.ts — never implicitly
// from this schema file.

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  // Explicit, not inferred: Prisma's "prisma-client" generator defaults
  // to ESM output and tries to infer the right format from
  // tsconfig.json when moduleFormat is unset. That inference guessed
  // wrong here — this project's tsconfig uses "module": "nodenext" but
  // apps/api/package.json has no "type" field, so the resulting
  // generated/prisma/client.js mixed ESM-only `import.meta.url` with
  // CJS `exports`/`require`, which neither Node nor ts-jest can parse
  // (docs/roadmap/Progress.md Known gaps has the full incident:
  // ReferenceError: exports is not defined in ES module scope, and
  // separately, ts-jest's SyntaxError: Cannot use 'import.meta' outside
  // a module — both the same root cause). apps/api itself compiles to
  // CommonJS-shaped output (node-app.json's "module": "CommonJS" base,
  // no "type": "module" anywhere), so cjs is the correct match, not
  // esm. Regenerate after this change with
  // `pnpm --filter @ai-defense/api exec prisma generate` on a machine
  // with network access to binaries.prisma.sh (this repo's sandbox
  // can't reach it — separate, already-documented gap) and verify
  // `node dist/main.js` boots before relying on this fix.
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum MissionStatus {
  DRAFT
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

model Mission {
  id             String        @id @default(uuid())
  title          String
  description    String?
  status         MissionStatus @default(DRAFT)
  videoObjectKey String?       @map("video_object_key")
  createdById    String        @map("created_by_id")
  createdBy      User          @relation(fields: [createdById], references: [id])
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  auditLogs      AuditLog[]
  detections     Detection[]
  telemetryPoints TelemetryPoint[]

  @@map("missions")
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String       @map("password_hash")
  displayName  String       @map("display_name")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  roles        UserRole[]
  teams        TeamMember[]
  missions     Mission[]
  auditLogs    AuditLog[]

  @@map("users")
}

model Team {
  id        String       @id @default(uuid())
  name      String       @unique
  createdAt DateTime     @default(now()) @map("created_at")
  members   TeamMember[]

  @@map("teams")
}

model TeamMember {
  teamId   String   @map("team_id")
  userId   String   @map("user_id")
  team     Team     @relation(fields: [teamId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  joinedAt DateTime @default(now()) @map("joined_at")

  @@id([teamId, userId])
  @@map("team_members")
}

// Role names are seed data (operator, admin per PRD-Phase-2 REQ-2.5),
// not user-editable in Phase 2 — no admin endpoint creates new roles.
model Role {
  id    String     @id @default(uuid())
  name  String     @unique
  users UserRole[]

  @@map("roles")
}

model UserRole {
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  user       User     @relation(fields: [userId], references: [id])
  role       Role     @relation(fields: [roleId], references: [id])
  assignedAt DateTime @default(now()) @map("assigned_at")

  @@id([userId, roleId])
  @@map("user_roles")
}

// Append-only per REQ-2.10 — no update/delete path exists in
// AuditModule; enforced at the application layer, not by a DB trigger,
// consistent with how MissionStatus transitions are enforced above the
// database (see Mission_State_Machine.md).
model AuditLog {
  id            String   @id @default(uuid())
  actorUserId   String?  @map("actor_user_id")
  actor         User?    @relation(fields: [actorUserId], references: [id])
  action        String
  targetType    String   @map("target_type")
  targetId      String?  @map("target_id")
  missionId     String?  @map("mission_id")
  mission       Mission? @relation(fields: [missionId], references: [id])
  correlationId String?  @map("correlation_id")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([missionId])
  @@index([actorUserId])
  @@map("audit_log")
}

// Phase 3 (docs/mvp-plan/PRD-Phase-3.md REQ-3.6/3.7/3.11): apps/outbox-publisher
// now polls and publishes this table. `eventId` is generated once by
// the application (crypto.randomUUID()) when the row is inserted and
// reused on every republish attempt, so the Kafka message's envelope
// eventId — and the processed_events row a consumer records against it
// (REQ-3.8) — stay stable across at-least-once redelivery.
// `correlationId`/`causationId` carry Phase 1's correlation baseline and
// REQ-3.12's causation chain through to the Kafka message headers.
//
// NOTE: this schema.prisma edit could not be applied via `prisma migrate
// dev`/`prisma generate` in this sandbox (binaries.prisma.sh is
// network-blocked here, see docs/roadmap/Progress.md Known gaps) — the
// matching hand-written SQL lives at
// apps/api/prisma/migrations/20260714120000_kafka_event_platform/migration.sql,
// and OutboxRepository/ProcessedEventsRepository use `$queryRaw`/
// `$executeRaw` against these columns rather than the generated
// `Outbox` delegate, which is stale until `prisma generate` runs on a
// machine with network access.
model Outbox {
  id            String    @id @default(uuid())
  eventId       String    @unique @map("event_id")
  aggregateType String    @map("aggregate_type")
  aggregateId   String    @map("aggregate_id")
  eventType     String    @map("event_type")
  payload       Json
  correlationId String?   @map("correlation_id")
  causationId   String?   @map("causation_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  publishedAt   DateTime? @map("published_at")

  @@index([publishedAt])
  @@map("outbox")
}

// Phase 6 (docs/mvp-plan/PRD-Phase-6.md REQ-6.1): persisted mirror of
// every retained DETECTION_PUBLISHED event on aidefense.detections, so
// apps/web can read a mission's full detection history (REQ-6.2) after
// processing completes, not just live off the WebSocket relay
// (REQ-6.5). `boundingBox` is stored as-is (jsonb) rather than four
// separate columns — same shape as the Kafka payload
// (packages/event-schemas/src/payloads.ts's `DetectionBoundingBox`), no
// translation needed at the read boundary. Append-only: nothing updates
// or deletes a row here, same posture as AuditLog.
//
// NOTE: like Outbox/ProcessedEvent above, this model could not be
// migrated via `prisma migrate dev`/`prisma generate` in this sandbox
// (binaries.prisma.sh network-blocked — see docs/roadmap/Progress.md
// Known gaps). The hand-written SQL is at
// apps/api/prisma/migrations/20260715090000_frontend_workspace/migration.sql.
// DetectionsRepository therefore uses `$queryRaw`/`$executeRaw` against
// these columns directly, exactly like OutboxRepository/
// ProcessedEventsRepository, rather than a generated `Detection`
// delegate that doesn't exist in the stale client.
model Detection {
  id               String   @id @default(uuid())
  missionId        String   @map("mission_id")
  mission          Mission  @relation(fields: [missionId], references: [id])
  frameIndex       Int      @map("frame_index")
  frameTimestampMs Int      @map("frame_timestamp_ms")
  trackId          Int      @map("track_id")
  label            String
  confidence       Float
  boundingBox      Json     @map("bounding_box")
  createdAt        DateTime @default(now()) @map("created_at")

  @@index([missionId])
  @@map("detections")
}

// Phase 7 (docs/mvp-plan/PRD-Phase-7.md REQ-7.1): ordered, timestamped
// telemetry points per mission, stored as a real PostGIS `geography`
// column — not a pair of plain float columns — per
// docs/decisions/Technology_Decisions.md's PostGIS rationale
// ("geospatial querying") and docs/adr/ADR-007-map-library-choice.md.
// `position` uses Prisma's `Unsupported(...)` type: Prisma has no
// native geography/geometry type, so this field is documented here for
// `prisma migrate diff`/schema-tracking purposes but is excluded from
// the generated client's `TelemetryPoint` delegate entirely (a
// documented Prisma limitation, not specific to this sandbox's
// stale-client issue) — `TelemetryRepository` always reads/writes it
// via `$queryRaw`/`$executeRaw` using `ST_MakePoint`/`ST_X`/`ST_Y`,
// exactly like every other raw-SQL-backed model below
// (Outbox/ProcessedEvent/Detection).
//
// NOTE: like those models, this one could not be migrated via `prisma
// migrate dev`/`prisma generate` in this sandbox (binaries.prisma.sh
// network-blocked — see docs/roadmap/Progress.md Known gaps). The
// hand-written SQL is at
// apps/api/prisma/migrations/20260715150000_gis_telemetry_platform/migration.sql.
model TelemetryPoint {
  id           String                    @id @default(uuid())
  missionId    String                    @map("mission_id")
  mission      Mission                   @relation(fields: [missionId], references: [id])
  capturedAt   DateTime                  @map("captured_at")
  position     Unsupported("geography(Point, 4326)")
  altitudeM    Float?                    @map("altitude_m")
  headingDeg   Float?                    @map("heading_deg")
  speedMps     Float?                    @map("speed_mps")
  createdAt    DateTime                  @default(now()) @map("created_at")

  @@index([missionId, capturedAt])
  @@map("telemetry_points")
}

// Phase 8 (docs/mvp-plan/PRD-Phase-8.md REQ-8.1/8.2): dataset registry
// metadata. Dataset *content* lives in MinIO under a
// `datasets/{id}/` prefix (docs/adr/ADR-008-experiment-tracking-and-dataset-versioning.md);
// this table holds only the catalog entry. `provenance`/`license` are
// required (NOT NULL, no default) rather than optional — REQ-8.2's
// validation gate is enforced at the application layer
// (DatasetsService) before a row is ever inserted, so a row existing at
// all is itself evidence the gate was satisfied, the same
// enforce-above-the-database posture Mission_State_Machine.md already
// documents for mission transitions.
//
// NOTE: like every model added since Phase 3, this could not be
// migrated via `prisma migrate dev`/`prisma generate` in this sandbox
// (binaries.prisma.sh network-blocked — see docs/roadmap/Progress.md
// Known gaps). Unlike TelemetryPoint, this model needs no
// `Unsupported(...)` column — plain relational columns throughout — so
// once `prisma generate` runs on a machine with network access,
// `DatasetsRepository` could move to the generated `dataset` delegate
// without a schema change. It still uses `$queryRaw`/`$executeRaw` for
// now, purely because of the stale-client limitation, not an
// architectural one. Hand-written SQL:
// apps/api/prisma/migrations/20260715190000_data_training_model_lifecycle/migration.sql.
model Dataset {
  id               String   @id @default(uuid())
  name             String
  version          String
  storageLocation  String   @map("storage_location")
  source           String
  collectionMethod String   @map("collection_method")
  license          String
  provenanceNotes  String   @map("provenance_notes")
  createdById      String?  @map("created_by_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  splits           DatasetSplit[]
  trainingRuns     TrainingRun[]

  @@unique([name, version])
  @@map("datasets")
}

// REQ-8.3: a deterministic, seeded train/validation/test split over a
// dataset's manifest (a newline-delimited item-id list uploaded per
// `POST /datasets/:id/splits`, mirroring the telemetry file-upload UX —
// see telemetry.types.ts). The three resulting item lists are written
// back to MinIO as their own manifest files (object keys recorded
// below) so a training run can fetch exactly the same three lists
// later without recomputing anything — recomputing from the seed alone
// would still be deterministic, but re-reading the persisted manifest
// avoids relying on the *input* manifest's on-disk order never
// changing between calls.
model DatasetSplit {
  id                          String   @id @default(uuid())
  datasetId                   String   @map("dataset_id")
  dataset                     Dataset  @relation(fields: [datasetId], references: [id])
  seed                        Int
  trainRatio                  Float    @map("train_ratio")
  validationRatio             Float    @map("validation_ratio")
  testRatio                   Float    @map("test_ratio")
  trainCount                  Int      @map("train_count")
  validationCount             Int      @map("validation_count")
  testCount                   Int      @map("test_count")
  trainManifestObjectKey      String   @map("train_manifest_object_key")
  validationManifestObjectKey String   @map("validation_manifest_object_key")
  testManifestObjectKey       String   @map("test_manifest_object_key")
  createdAt                   DateTime @default(now()) @map("created_at")
  trainingRuns                TrainingRun[]

  @@index([datasetId])
  @@map("dataset_splits")
}

// REQ-8.7/8.8/8.13/8.14: one row per training run, written once by
// `apps/vision-service`'s training script (`training/registry_client.py`)
// after the run completes — this is the "experiment tracker"
// docs/adr/ADR-008-experiment-tracking-and-dataset-versioning.md
// decided to build in-house rather than adopt MLflow. `metrics` and
// `evaluationReport` are JSON rather than normalized columns: their
// shape (per-epoch series, per-class precision/recall/mAP, flagged
// low-performing classes, human-written failure notes) is read/written
// wholesale by exactly one producer and one set of readers, with no
// query need finer than "this run's report", so normalizing further
// would add join complexity with no corresponding benefit — consistent
// with Guiding_Principles.md's "Simplicity over Complexity".
model TrainingRun {
  id               String        @id @default(uuid())
  datasetId        String        @map("dataset_id")
  dataset          Dataset       @relation(fields: [datasetId], references: [id])
  datasetSplitId   String        @map("dataset_split_id")
  datasetSplit     DatasetSplit  @relation(fields: [datasetSplitId], references: [id])
  gitCommit        String?       @map("git_commit")
  hyperparameters  Json
  // "RUNNING" | "COMPLETED" | "FAILED" — a plain string, not an enum,
  // mirroring AuditLog.action's existing plain-string convention for a
  // small, non-relational status field.
  status           String
  metrics          Json
  evaluationReport Json?         @map("evaluation_report")
  startedAt        DateTime      @map("started_at")
  completedAt      DateTime?     @map("completed_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  modelVersions    ModelVersion[]

  @@index([datasetId])
  @@map("training_runs")
}

enum ModelStage {
  CANDIDATE
  STAGED
  PRODUCTION
  RETIRED
}

// REQ-8.9-8.12: one row per exported `.onnx` artifact (MinIO-stored
// under `models/{id}/`), with lineage back to the training run that
// produced it. `stage` is the only mutable column after creation —
// REQ-8.10/8.11's promote/rollback actions update it (and
// `promotedAt`/`promotedById`), each such change also writing an
// AuditLog row via the existing AuditService (REQ-8.12), the same
// append-only-audit-alongside-a-mutable-state-change shape
// MissionsService.transition() already established for REQ-2.8.
model ModelVersion {
  id            String      @id @default(uuid())
  trainingRunId String      @map("training_run_id")
  trainingRun   TrainingRun @relation(fields: [trainingRunId], references: [id])
  objectKey     String      @map("object_key")
  stage         ModelStage  @default(CANDIDATE)
  createdAt     DateTime    @default(now()) @map("created_at")
  promotedAt    DateTime?   @map("promoted_at")
  promotedById  String?     @map("promoted_by_id")

  @@index([stage])
  @@map("model_versions")
}

// Phase 9 (docs/mvp-plan/PRD-Phase-9.md REQ-9.9/9.10): one row per
// registered edge device. `tokenHash` is a SHA-256 hex digest of the
// device's bearer credential — the credential itself is returned once,
// at registration time, and never stored (docs/adr/ADR-011-device-identity-and-sync-transport.md).
// `deviceId` is the human-chosen label (e.g. "jetson-01") a device
// authenticates and synchronizes as; `id` is the usual surrogate key.
// `revokedAt` is the only supported way to invalidate a device's access
// — there is no token rotation in this phase (see the ADR's Consequences
// section).
//
// NOTE: like every model added since Phase 3, this could not be
// migrated via `prisma migrate dev`/`prisma generate` in this sandbox
// (binaries.prisma.sh network-blocked — see docs/roadmap/Progress.md
// Known gaps). Plain relational columns throughout, so once `prisma
// generate` runs on a machine with network access, `EdgeDevicesRepository`
// could move to the generated `edgeDevice` delegate without a schema
// change. Hand-written SQL:
// apps/api/prisma/migrations/20260715210000_edge_runtime/migration.sql.
model EdgeDevice {
  id            String    @id @default(uuid())
  deviceId      String    @unique @map("device_id")
  tokenHash     String    @unique @map("token_hash")
  displayName   String?   @map("display_name")
  createdById   String?   @map("created_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  lastSeenAt    DateTime? @map("last_seen_at")
  lastSyncAt    DateTime? @map("last_sync_at")
  revokedAt     DateTime? @map("revoked_at")

  @@map("edge_devices")
}

// REQ-3.8: idempotent consumption on both sides of the broker. One row
// per (eventId, consumer) — `apps/api` and `apps/vision-service` each
// record their own consumer name, so the same eventId can be safely
// processed once by each side. `apps/vision-service` accesses this
// table directly over a scoped Postgres connection (see
// docs/python/Vision_Service_Shell.md) — everything else in that
// service goes through Kafka, not Postgres.
model ProcessedEvent {
  id          String   @id @default(uuid())
  eventId     String   @map("event_id")
  consumer    String
  processedAt DateTime @default(now()) @map("processed_at")

  @@unique([eventId, consumer])
  @@map("processed_events")
}
