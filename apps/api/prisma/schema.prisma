// Phase 2 data model — docs/mvp-plan/PRD-Phase-2.md REQ-2.1.
// ORM choice: docs/adr/ADR-004-nestjs-orm.md (Prisma).
// Mission state machine: docs/architecture/Mission_State_Machine.md.
//
// The datasource has no `url` field: in Prisma 7 the CLI (migrate,
// generate) reads the connection string from prisma.config.ts, and the
// runtime PrismaClient receives it explicitly via the @prisma/adapter-pg
// driver adapter in src/prisma/prisma.service.ts — never implicitly
// from this schema file.

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MissionStatus {
  DRAFT
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

model Mission {
  id             String        @id @default(uuid())
  title          String
  description    String?
  status         MissionStatus @default(DRAFT)
  videoObjectKey String?       @map("video_object_key")
  createdById    String        @map("created_by_id")
  createdBy      User          @relation(fields: [createdById], references: [id])
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")
  auditLogs      AuditLog[]

  @@map("missions")
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String       @map("password_hash")
  displayName  String       @map("display_name")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  roles        UserRole[]
  teams        TeamMember[]
  missions     Mission[]
  auditLogs    AuditLog[]

  @@map("users")
}

model Team {
  id        String       @id @default(uuid())
  name      String       @unique
  createdAt DateTime     @default(now()) @map("created_at")
  members   TeamMember[]

  @@map("teams")
}

model TeamMember {
  teamId   String   @map("team_id")
  userId   String   @map("user_id")
  team     Team     @relation(fields: [teamId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
  joinedAt DateTime @default(now()) @map("joined_at")

  @@id([teamId, userId])
  @@map("team_members")
}

// Role names are seed data (operator, admin per PRD-Phase-2 REQ-2.5),
// not user-editable in Phase 2 — no admin endpoint creates new roles.
model Role {
  id    String     @id @default(uuid())
  name  String     @unique
  users UserRole[]

  @@map("roles")
}

model UserRole {
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  user       User     @relation(fields: [userId], references: [id])
  role       Role     @relation(fields: [roleId], references: [id])
  assignedAt DateTime @default(now()) @map("assigned_at")

  @@id([userId, roleId])
  @@map("user_roles")
}

// Append-only per REQ-2.10 — no update/delete path exists in
// AuditModule; enforced at the application layer, not by a DB trigger,
// consistent with how MissionStatus transitions are enforced above the
// database (see Mission_State_Machine.md).
model AuditLog {
  id            String   @id @default(uuid())
  actorUserId   String?  @map("actor_user_id")
  actor         User?    @relation(fields: [actorUserId], references: [id])
  action        String
  targetType    String   @map("target_type")
  targetId      String?  @map("target_id")
  missionId     String?  @map("mission_id")
  mission       Mission? @relation(fields: [missionId], references: [id])
  correlationId String?  @map("correlation_id")
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([missionId])
  @@index([actorUserId])
  @@map("audit_log")
}

// Columns only in Phase 2 — no publisher reads this table yet
// (apps/outbox-publisher stays an empty stub until Phase 3 per
// PRD-Phase-1 REQ-1.6 / PRD-Phase-2 non-goals).
model Outbox {
  id            String    @id @default(uuid())
  aggregateType String    @map("aggregate_type")
  aggregateId   String    @map("aggregate_id")
  eventType     String    @map("event_type")
  payload       Json
  createdAt     DateTime  @default(now()) @map("created_at")
  publishedAt   DateTime? @map("published_at")

  @@index([publishedAt])
  @@map("outbox")
}
